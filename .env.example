# Database — Neon Postgres (free): https://neon.tech
# Dashboard → your project → Connection string → copy "URI"
# Must include ?sslmode=require at the end
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"

# Local: http://localhost:3000
# Vercel: https://your-project.vercel.app (no slash at end)
NEXTAUTH_URL="http://localhost:3000"

# OpenAI (optional — leave blank to use free demo mode)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Force demo mode even if you have an API key
USE_DEMO_MODE="false"
